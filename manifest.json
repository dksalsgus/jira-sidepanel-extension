{
  "manifest_version": 3,
  "name": "Please Be Done",
  "version": "1.1.0",
  "description": "Please Be Done — 내게 할당된 Jira 티켓을 빠르게 확인",
  "minimum_chrome_version": "114",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://*.atlassian.net/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "Please Be Done",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
